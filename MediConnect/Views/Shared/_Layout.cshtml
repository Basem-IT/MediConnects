<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediConnect</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MediConnect.styles.css" asp-append-version="true" />
</head>
<body>

    @if (!(ViewContext.RouteData.Values["controller"]?.ToString() == "Account"))
    {
        <header>

            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">

                    <a class="navbar-brand d-flex align-items-center"
                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">

                        <img src="/Images/logoMediConnect.png"
                             alt="MediConnect Logo"
                             style="height:75px; width:auto; margin-right:18px; display:block;" />

                    </a>

                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                        <ul class="navbar-nav flex-grow-1">

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-area=""
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Home
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Doctors"
                                   asp-action="Index">
                                    Doctors
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Patients"
                                   asp-action="Index">
                                    Patients
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Schedules"
                                   asp-action="Index">
                                    Schedules
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Appointments"
                                   asp-action="Index">
                                    Appointments
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Notifications"
                                   asp-action="Index">
                                    Notifications
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="MedicalRecords"
                                   asp-action="Index">
                                    Medical Records
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Prescriptions"
                                   asp-action="Index">
                                    Prescriptions
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-area=""
                                   asp-controller="Home"
                                   asp-action="Privacy">
                                    Privacy
                                </a>
                            </li>

                        </ul>

                        @if (Context.Session.GetString("UserName") != null)
                        {
                            <div class="dropdown ms-auto">
                                <button class="btn rounded-circle"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        style="width:45px; height:45px; background:#ff4fa3; color:white; font-weight:bold; margin:auto;">
                                    @Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper()
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end p-3" style="width:260px;">
                                    <li>
                                        <strong>Hello, @Context.Session.GetString("UserName")</strong>
                                    </li>

                                    <li class="text-muted">
                                        Role: @Context.Session.GetString("Role")
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Account"
                                           asp-action="Profile">
                                            Edit Info
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item text-danger"
                                           asp-controller="Account"
                                           asp-action="Logout"
                                           onclick="return confirm('Are you sure you want to logout?');">
                                            Logout
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }

                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MediConnect -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/9.0.6/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
