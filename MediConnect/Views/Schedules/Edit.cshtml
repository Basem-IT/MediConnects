@model MediConnectAPI.Models.Schedule

<div class="container py-4" style="max-width:600px;">
    <h2 class="fw-bold mb-4" style="color:#ff4fa3;">Edit Schedule</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ScheduleID" />

        <div class="mb-3">
            <label class="form-label fw-semibold">Doctor</label>
            <select asp-for="DoctorID" class="form-select" asp-items="ViewBag.DoctorID"></select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Day of Week</label>
            <select asp-for="DayOfWeek" class="form-select" asp-items="ViewBag.Days">
                <option value="">-- Select Day --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Start Time</label>
            <input asp-for="StartTime" type="time" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">End Time</label>
            <input asp-for="EndTime" type="time" class="form-control" />
        </div>

        <div class="mb-3 form-check">
            <input asp-for="IsAvailable" class="form-check-input" />
            <label class="form-check-label">Available</label>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>