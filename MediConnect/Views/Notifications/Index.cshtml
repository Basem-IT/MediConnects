@model IEnumerable<MediConnectAPI.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<h1>Notifications</h1>

<table class="table">
    <thead>
        <tr>
            <th>Type</th>
            <th>Message</th>
            <th>Appointment</th>
            <th>Date</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var notification in Model)
        {
            <tr>
                <td>@notification.Type</td>

                <td>@notification.Message</td>

                <td>
                    Appointment #@notification.AppointmentID
                </td>

                <td>
                    @notification.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                </td>

                <td>
                    @if (notification.IsRead)
                    {
                        <span class="badge bg-secondary">Read</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">Unread</span>
                    }
                </td>

                <td>
                    @if (!notification.IsRead)
                    {
                        <a asp-action="MarkAsRead"
                           asp-route-id="@notification.NotificationID"
                           class="btn btn-success btn-sm">
                            Mark as Read
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>