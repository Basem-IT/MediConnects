@model MediConnectAPI.Models.Patient

<h1>Add Patient</h1>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label>CPR</label>
        <input asp-for="CPR" class="form-control" />
    </div>

    <div class="mb-3">
        <label>DOB</label>
        <input asp-for="DOB" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Phone</label>
        <input asp-for="Phone" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Add Patient
    </button>

</form>