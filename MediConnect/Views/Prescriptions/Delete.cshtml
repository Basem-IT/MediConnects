@model MediConnectAPI.Models.Prescription

<h1>Delete Prescription</h1>

<h3>Are you sure you want to delete this prescription?</h3>

<p><strong>Medication:</strong> @Model.MedicationName</p>
<p><strong>Dosage:</strong> @Model.Dosage</p>
<p><strong>Frequency:</strong> @Model.Frequency</p>
<p><strong>Duration:</strong> @Model.Duration</p>

<form asp-action="Delete">
    <input type="hidden" asp-for="PrescriptionID" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>