@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string;
    var userName = ViewBag.UserName as string;
}

<div class="container py-4">

    <div class="mb-4">
        <h2>Welcome back, <strong>@userName</strong> 👋</h2>
        <p class="text-muted">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</p>
    </div>

    @if (role == "ClinicManager")
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card h-100" style="background: linear-gradient(135deg,#ff4fa3,#ff7dc1); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Total Doctors</p>
                        <h2 class="fw-bold">@ViewBag.TotalDoctors</h2>
                        <p class="mb-0 small opacity-75">👨‍⚕️ Registered</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100" style="background: linear-gradient(135deg,#a855f7,#c084fc); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Total Patients</p>
                        <h2 class="fw-bold">@ViewBag.TotalPatients</h2>
                        <p class="mb-0 small opacity-75">🧑‍🤝‍🧑 Registered</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100" style="background: linear-gradient(135deg,#f59e0b,#fbbf24); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Today's Appointments</p>
                        <h2 class="fw-bold">@ViewBag.TodayAppointments</h2>
                        <p class="mb-0 small opacity-75">📅 Scheduled</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100" style="background: linear-gradient(135deg,#ef4444,#f87171); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Pending Requests</p>
                        <h2 class="fw-bold">@ViewBag.PendingAppointments</h2>
                        <p class="mb-0 small opacity-75">⏳ Awaiting</p>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="mb-3 fw-bold" style="color:#ff4fa3;">Quick Access</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <a href="/Doctors" class="text-decoration-none">
                    <div class="card text-center p-3 h-100" style="border: 2px solid #ffe4f0;">
                        <div class="card-body">
                            <div style="font-size:2.5rem;">👨‍⚕️</div>
                            <h5 class="mt-2 fw-bold" style="color:#ff4fa3;">Manage Doctors</h5>
                            <p class="text-muted small">View and manage doctor profiles</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Patients" class="text-decoration-none">
                    <div class="card text-center p-3 h-100" style="border: 2px solid #ffe4f0;">
                        <div class="card-body">
                            <div style="font-size:2.5rem;">🧑‍🤝‍🧑</div>
                            <h5 class="mt-2 fw-bold" style="color:#ff4fa3;">Manage Patients</h5>
                            <p class="text-muted small">View and manage patient records</p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Appointments" class="text-decoration-none">
                    <div class="card text-center p-3 h-100" style="border: 2px solid #ffe4f0;">
                        <div class="card-body">
                            <div style="font-size:2.5rem;">📅</div>
                            <h5 class="mt-2 fw-bold" style="color:#ff4fa3;">Appointments</h5>
                            <p class="text-muted small">View and manage appointments</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    }

    @if (role == "Doctor")
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card h-100" style="background: linear-gradient(135deg,#ff4fa3,#ff7dc1); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Today's Appointments</p>
                        <h2 class="fw-bold">@(ViewBag.TotalToday ?? 0)</h2>
                        <p class="mb-0 small opacity-75">📅 Scheduled today</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100" style="background: linear-gradient(135deg,#a855f7,#c084fc); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Completed</p>
                        <h2 class="fw-bold">@(ViewBag.TotalCompleted ?? 0)</h2>
                        <p class="mb-0 small opacity-75">✅ All time</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100" style="background: linear-gradient(135deg,#f59e0b,#fbbf24); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Unread Notifications</p>
                        <h2 class="fw-bold">@(ViewBag.UnreadNotifications ?? 0)</h2>
                        <p class="mb-0 small opacity-75">🔔 Unread</p>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="mb-3 fw-bold" style="color:#ff4fa3;">📋 Upcoming Appointments</h5>
        @if (ViewBag.UpcomingAppointments != null && ((List<MediConnectAPI.Models.Appointment>)ViewBag.UpcomingAppointments).Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Date & Time</th>
                            <th>Reason</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in (List<MediConnectAPI.Models.Appointment>)ViewBag.UpcomingAppointments)
                        {
                            <tr>
                                <td>@a.Patient?.Name</td>
                                <td>@a.AppointmentDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td>@a.Reason</td>
                                <td>
                                    <span class="badge" style="background: linear-gradient(135deg,#ff4fa3,#ff7dc1);">
                                        @a.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">No upcoming appointments.</div>
        }
    }

    @if (role == "Patient")
    {
        <h5 class="mb-3 fw-bold" style="color:#ff4fa3;">📅 Your Upcoming Appointments</h5>
        @if (ViewBag.UpcomingAppointments != null && ((List<MediConnectAPI.Models.Appointment>)ViewBag.UpcomingAppointments).Count > 0)
        {
            @foreach (var a in (List<MediConnectAPI.Models.Appointment>)ViewBag.UpcomingAppointments)
            {
                <div class="card mb-3" style="border-left: 4px solid #ff4fa3;">
                    <div class="card-body">
                        <h6 class="fw-bold" style="color:#ff4fa3;">Dr. @a.Doctor?.Name</h6>
                        <p class="mb-1 text-muted">📅 @a.AppointmentDate.ToString("dddd, MMM dd yyyy - hh:mm tt")</p>
                        <p class="mb-1 text-muted">📝 @a.Reason</p>
                        <span class="badge" style="background: linear-gradient(135deg,#ff4fa3,#ff7dc1);">
                            @a.Status
                        </span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">
                No upcoming appointments.
                <a href="/Appointments/Create" style="color:#ff4fa3;">Book one now</a>.
            </div>
        }
    }

    @if (role == "Receptionist")
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card h-100" style="background: linear-gradient(135deg,#ff4fa3,#ff7dc1); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Today's Appointments</p>
                        <h2 class="fw-bold">@(ViewBag.TodayAppointments ?? 0)</h2>
                        <p class="mb-0 small opacity-75">📅 Scheduled</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100" style="background: linear-gradient(135deg,#f59e0b,#fbbf24); color:white;">
                    <div class="card-body">
                        <p class="mb-1 opacity-75">Pending Requests</p>
                        <h2 class="fw-bold">@(ViewBag.PendingAppointments ?? 0)</h2>
                        <p class="mb-0 small opacity-75">⏳ Awaiting confirmation</p>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="mb-3 fw-bold" style="color:#ff4fa3;">📋 Today's Schedule</h5>
        @if (ViewBag.TodayList != null && ((List<MediConnectAPI.Models.Appointment>)ViewBag.TodayList).Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in (List<MediConnectAPI.Models.Appointment>)ViewBag.TodayList)
                        {
                            <tr>
                                <td>@a.Patient?.Name</td>
                                <td>@a.Doctor?.Name</td>
                                <td>@a.AppointmentDate.ToString("hh:mm tt")</td>
                                <td><span class="badge bg-secondary">@a.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">No appointments today.</div>
        }
    }

</div>