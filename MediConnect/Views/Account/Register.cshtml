@model MediConnectMVC.ViewModels.RegisterViewModel
<h1>Register</h1>
<form asp-action="Register" method="post">
    <div class="mb-3">
        <label>Username</label>
        <input asp-for="UserName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Password</label>
        <input asp-for="Password" type="password" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Confirm Password</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Role</label>
        <select asp-for="RoleName" class="form-control">
            <option value="Patient">Patient</option>
            <option value="Doctor">Doctor</option>
            <option value="Receptionist">Receptionist</option>
            <option value="ClinicManager">Clinic Manager</option>
        </select>
    </div>
    <div class="mb-3">
        <label>Full Name</label>
        <input asp-for="FullName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label>CPR</label>
        <input asp-for="CPR" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Phone (+973)</label>
        <input asp-for="Phone" class="form-control" placeholder="e.g. 33001234" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label>Date of Birth</label>
        <input asp-for="DOB" type="date" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Register</button>
    <a asp-action="Login" class="btn btn-secondary">Back to Login</a>
</form>
@if (ViewBag.Error != null)
{
    <div class="text-danger mt-3">@ViewBag.Error</div>
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}