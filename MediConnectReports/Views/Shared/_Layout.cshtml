<!DOCTYPE html>
<html lang="en" style="height:100%;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediConnect Reports</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            font-family: "Segoe UI", sans-serif;
            background: #f7f8fc;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding-top: 70px;
        }

        .modern-navbar {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid #eee;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
        }

        .table th {
            background: #fff0f7;
            color: #ff4fa3;
            font-weight: 700;
        }

        .table {
            background: white;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 8px 25px rgba(0,0,0,0.04);
        }

        .btn-primary {
            background: linear-gradient(135deg,#ff4fa3,#ff7dc1);
            border: none;
            border-radius: 12px;
        }

            .btn-primary:hover {
                opacity: 0.9;
            }

        .card {
            border: none;
            border-radius: 18px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.04);
        }

        .container {
            flex: 1;
            animation: fadeIn 0.4s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        footer {
            background: white;
            border-top: 1px solid #eee;
            padding: 15px 0;
            margin-top: auto;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar modern-navbar fixed-top px-4">
            <a class="navbar-brand" href="#">
                <span style="color:#ff4fa3; font-weight:700; font-size:1.3rem;">MediConnect</span>
            </a>
            <span class="fw-semibold text-muted">Reports</span>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container text-muted text-center">
            &copy; 2026 - MediConnect Reports
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>