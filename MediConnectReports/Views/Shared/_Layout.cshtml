<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>MediConnect Reports</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
            background: #f4f6f8;
        }

        header {
            background: #1f4e79;
            color: white;
            padding: 15px 30px;
        }

        main {
            padding: 30px;
        }

        .card {
            background: white;
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 8px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 10px;
        }

        th {
            background: #1f4e79;
            color: white;
        }

        input, button {
            padding: 10px;
            margin: 5px 0;
            width: 100%;
        }

        button {
            background: #1f4e79;
            color: white;
            border: none;
            cursor: pointer;
        }

        .error {
            color: red;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }
    </style>
</head>
<body>
    <header>
        <h2>MediConnect Reporting Application</h2>
    </header>

    <main>
        @RenderBody()
    </main>
</body>
</html>