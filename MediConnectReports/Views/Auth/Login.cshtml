@model LoginViewModel

<div style="min-height:80vh; display:flex; align-items:center; justify-content:center;">
    <div class="card p-4" style="width:100%; max-width:420px;">

        <div class="text-center mb-4">
            <h3 style="color:#ff4fa3; font-weight:700;">Welcome Back</h3>
            <p class="text-muted">Sign in to MediConnect Reports</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Username</label>
                <input asp-for="UserName" class="form-control" placeholder="Enter username" />
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>

    </div>
</div>